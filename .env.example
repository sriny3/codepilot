# --- GitHub ---
GITHUB_TOKEN=ghp_replace_me
GITHUB_APP_ID=<your-app-id>
GITHUB_APP_PRIVATE_KEY=<path/to/key.pem or raw PEM contents>
REPO_FULL_NAME=org/repo

# --- LLM provider (one required) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Polling / runtime ---
POLL_INTERVAL_MIN=5
MAX_RETRIES=3
TOKEN_BUDGET_REPOMAP=4000
COMPLEXITY_THRESHOLD=6
MAX_INFLIGHT_TASKS=2

# --- Vector store ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Observability ---
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_FORMAT=json
OTEL_EXPORTER_OTLP_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=codepilot
